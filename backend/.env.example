# Environment
NODE_ENV=development

# Server
PORT=3001

# Database
# `DATABASE_URL` is the canonical connection string used by this app (used in
# server and seed scripts). `MONGODB_URI` is left for compatibility with some
# tools/libraries; keep it in sync if you change `DATABASE_URL`.
DATABASE_URL=mongodb://localhost:27017/streamHub
MONGODB_URI=mongodb://localhost:27017/streamHub

# Authentication
JWT_SECRET=your-secret-key-here

# WebRTC Configuration
# For local development: Use your local IP (run: ifconfig | grep "inet " | grep -v 127.0.0.1)
# For production: Use your server's public IP
ANNOUNCED_IP=your-local-ip-here

# MediaSoup RTC Port Range
# Each WebRTC connection uses 1-2 UDP ports from this range
# Larger range = more concurrent connections possible
# Make sure your firewall allows UDP traffic on this range
# Development: 10,000 ports = ~10,000 concurrent connections
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# Maximum MediaSoup workers (typically 1 per CPU core, max 8)
MAX_WORKERS=8

# CORS & Client
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000

# Optional Services (if using)
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672

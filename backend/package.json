    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.2.1",
    "fix-webm-duration": "^1.0.6",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.12.0",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "prom-client": "^14.2.0",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.7.2",

{
  "name": "ils-backend",
  "version": "1.0.0",
  "description": "Interactive Live Streaming Backend",
  "main": "server.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "dev": "tsx --env-file=.env.local watch server.ts",
